{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=AspNetSpaTemplate;Trusted_Connection=true;TrustServerCertificate=true;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "AspnetSpaTemplate": {
    "Environment": "Development",
    "JwtSecret": "REPLACE_WITH_A_SECURE_RANDOM_KEY",
    "JwtExpiration": 3600,
    "Webhooks": {
      "PaymentProviderSecret": "REPLACE_WITH_WEBHOOK_SECRET_FOR_PAYMENT_PROVIDER",
      "EmailServiceSecret": "REPLACE_WITH_WEBHOOK_SECRET_FOR_EMAIL_SERVICE",
      "ShippingProviderSecret": "REPLACE_WITH_WEBHOOK_SECRET_FOR_SHIPPING_PROVIDER"
    },
    "RequestLogging": {
      "Enabled": true,
      "VerbosityLevel": "Standard",
      "LogRequestHeaders": false,
      "LogRequestBody": false,
      "LogResponseBody": false,
      "SlowRequestThresholdMs": 1000,
      "ExcludedPaths": []
    }
  }
}
